EDC_CONNECTOR_IMAGE=edc-connector:latest
FEDERATED_CATALOG_API_KEY=fc_5f1a3c9d2e7b4a8c91d6e0f2b7a4c8d1

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
