# Mongo
MONGODB_URI=mongodb://edc_mongo:27017
MONGODB_DB=edc_backend

# Postgres
POSTGRES_DB=edc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_HOST=edc_postgres
POSTGRES_PORT=5432

# Backend
RUNTIME_PATH=/path/to/runtime
NETWORK_NAME=edc_network
TYPE=compose

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://edc_minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=edc-files
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

