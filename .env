# Postgres
POSTGRES_DB=edc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_HOST=edc_postgres
POSTGRES_PORT=5432

# Backend
RUNTIME_PATH=/home/juan/EDC_Studio/runtime
NETWORK_NAME=edc_network
